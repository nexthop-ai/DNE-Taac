# Template for scripts/_cache-config.sh — copy this file and fill in your
# environment's value to wire up the fbthrift install-tree cache.
#
#     cp scripts/_cache-config.sh.example scripts/_cache-config.sh
#     # edit scripts/_cache-config.sh
#
# `_cache-config.sh` is gitignored — it holds infrastructure-specific
# details that don't belong in the committed repo. Without this file
# the cache feature silently no-ops and builds fall through to the
# normal source compile.
#
# The host-side cache scripts (taac-cache-pull.sh, taac-cache-push.sh,
# taac-cache-build.sh) source this file when present.
#
# In CI, set the same variable at job level via repo vars / secrets —
# no committed config file needed.

# Full URI to the cache tarball. The pull/push scripts dispatch on
# scheme; supported schemes:
#
#     file:///abs/path/fbthrift-python-<rev>.tar.gz
#     ng://bucket/path/fbthrift-python-<rev>.tar.gz       (pull + push)
#     s3://bucket/path/fbthrift-python-<rev>.tar.gz       (pull + push)
#     https://host/path/fbthrift-python-<rev>.tar.gz      (pull only)
#
# The URI names the full object — there's no manifest-rev composition
# anymore. When the manifest pin moves, update TAAC_CACHE_URI to point
# at the new build's tarball (or let CI compose it from the rev).
TAAC_CACHE_URI=""
