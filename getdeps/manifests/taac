[manifest]
name = taac

[git]
repo_url = https://github.com/facebook/DNE-TaaC.git

[build]
builder = cmake

# IMPORTANT: docker/Dockerfile.taac's builder stage invokes
#   getdeps build --no-deps taac
# to skip dep re-assessment (the deps are built earlier in the same
# stage). Any new entry below MUST also be added to the dep-build
# RUN block in Dockerfile.taac.
[dependencies]
fbthrift-python
fboss-thrift-defs

[cmake.defines]
TAAC_BUILD_PYTHON_THRIFT=ON

[debs]
python3
python3-dev
python3-pip
python3-venv
