[manifest]
name = taac

[git]
repo_url = https://github.com/nexthop-ai/private-DNE-Taac.git

[build]
builder = cmake

# IMPORTANT: docker/Dockerfile.taac's Layer F invokes
#   getdeps build --no-deps taac
# to skip dep re-assessment (the cache restore in Layer A2 + the
# explicit pre-build in Layer B already cover the deps). Any new entry
# below MUST either:
#   (a) be added to Layer B's explicit pre-build list in
#       docker/Dockerfile.taac (and Dockerfile.fbthrift's mirror), OR
#   (b) be paired with dropping --no-deps from Layer F (accept the
#       per-build cost of getdeps's dep-assessment pass).
[dependencies]
fbthrift-python
fboss-thrift-defs

[cmake.defines]
TAAC_BUILD_PYTHON_THRIFT=ON

[debs]
python3
python3-dev
python3-pip
python3-venv
